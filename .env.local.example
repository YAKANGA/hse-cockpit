# ── Authentification NextAuth v5 ─────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_32_CHARS

# URL de l'application (automatique sur Vercel)
NEXTAUTH_URL=http://localhost:3000

# ── Base de données ───────────────────────────────────────────
# SQLite local (développement) — chemin relatif à la racine du projet
# En production Vercel, utiliser Neon/Supabase Postgres à la place :
# DATABASE_URL=postgresql://user:password@host:5432/hse_db

# ── Stockage fichiers (optionnel) ─────────────────────────────
# Pour stocker les fichiers Excel importés sur Vercel Blob :
# BLOB_READ_WRITE_TOKEN=vercelblob_rw_...

# ── Email (notifications, réinitialisation mot de passe) ─────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=motdepasse

# ── Comptes de démonstration (mots de passe initiaux) ─────────
# superadmin@platform.local  → Admin@2026
# a.kouadio@acme.local       → Acme@2026
# s.traore@acme.local        → Hse@2026
# n.kone@medlog.local        → Viewer@2026
# m.diallo@acme.local        → Import@2026
