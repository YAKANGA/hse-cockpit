{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/imports/route.ts":                      { "maxDuration": 30 },
    "app/api/exports/[moduleId]/route.ts":           { "maxDuration": 30 },
    "app/api/reports/global/pdf/route.ts":           { "maxDuration": 60 },
    "app/api/reports/global/docx/route.ts":          { "maxDuration": 60 },
    "app/api/reports/tenants/[tenantId]/pdf/route.ts": { "maxDuration": 60 },
    "app/api/reports/tenants/[tenantId]/docx/route.ts":{ "maxDuration": 60 },
    "app/api/reports/modules/[moduleId]/pdf/route.ts": { "maxDuration": 30 },
    "app/api/reports/modules/[moduleId]/docx/route.ts":{ "maxDuration": 30 },
    "app/api/admin/users/route.ts":                  { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';"
        },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security","value": "max-age=31536000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api/operations/health" }
  ]
}
