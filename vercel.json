{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/imports/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/global/pdf/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/global/docx/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/tenants/[tenantId]/pdf/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/tenants/[tenantId]/docx/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/modules/[moduleId]/pdf/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/modules/[moduleId]/docx/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/operations/health"
    }
  ]
}
