# ── Application HSE — Variables d'environnement ──────────────────────────────
# Copier ce fichier en .env.local pour le développement local.
# Sur Vercel : configurer chaque variable dans Settings > Environment Variables.

# ── Base de données (PostgreSQL via Vercel Postgres ou Neon) ──────────────────
# Requis pour la persistance des imports, utilisateurs, audit et tenants.
DATABASE_URL=postgresql://user:password@host:5432/hse_db?sslmode=require
DATABASE_DIRECT_URL=postgresql://user:password@host:5432/hse_db

# ── Authentification (NextAuth.js ou Clerk) ───────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://votre-domaine.vercel.app

# ── Stockage fichiers (Vercel Blob ou AWS S3) ─────────────────────────────────
# Requis pour stocker les fichiers Excel importés et les rapports générés.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Cache (Vercel KV / Upstash Redis) ────────────────────────────────────────
# Requis pour la mise en cache des dashboards fréquemment consultés.
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Configuration application ─────────────────────────────────────────────────
# URL publique de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=https://votre-domaine.vercel.app

# Environnement : development | staging | production
NODE_ENV=production

# Timezone par défaut pour les dates HSE
TZ=Africa/Abidjan

# ── Super Admin (accès initial) ───────────────────────────────────────────────
# Email du premier administrateur plateforme — à configurer avant le déploiement
SUPER_ADMIN_EMAIL=admin@votre-organisation.ci
SUPER_ADMIN_PASSWORD=changeme-strong-password

# ── Observabilité (optionnel) ─────────────────────────────────────────────────
# Sentry pour la capture des erreurs en production
SENTRY_DSN=https://xxxxxxxx@oxxxxxxxx.ingest.sentry.io/xxxxxxxx

# ── Email transactionnel (optionnel) ─────────────────────────────────────────
# Pour les notifications et exports par email
SMTP_HOST=smtp.votre-provider.com
SMTP_PORT=587
SMTP_USER=noreply@votre-organisation.ci
SMTP_PASS=changeme
SMTP_FROM=HSE Cockpit <noreply@votre-organisation.ci>
